<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Launch theme: shown during cold start / splash -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/launch_background</item>
        <item name="android:statusBarColor">@color/navy_deep</item>
        <item name="android:navigationBarColor">@color/navy_deep</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Normal theme: after Flutter engine loads -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/normal_background</item>
        <item name="android:statusBarColor">@color/navy_deep</item>
        <item name="android:navigationBarColor">@color/navy_deep</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
