# Guardian Dashboard — Environment Variables
# Copy this file to .env for local dev, or set these in Vercel Dashboard → Settings → Environment Variables

# ── Firebase (REQUIRED) ────────────────────────────────────────────
# The only value with no fallback. Get from Firebase Console → Project Settings → Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key_here

# ── Firebase (OPTIONAL — fallbacks already set in firebase.js) ────
# Only override these if your project ID differs from 'drishti-link'
# VITE_FIREBASE_AUTH_DOMAIN=drishti-link.firebaseapp.com
# VITE_FIREBASE_DATABASE_URL=https://drishti-link-default-rtdb.asia-southeast1.firebasedatabase.app
# VITE_FIREBASE_PROJECT_ID=drishti-link
# VITE_FIREBASE_STORAGE_BUCKET=drishti-link.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=176369639596
# VITE_FIREBASE_APP_ID=1:176369639596:web:045634643ca55b38e7ff09
